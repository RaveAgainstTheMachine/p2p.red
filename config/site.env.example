# Config template for Self-Hosters

# === Required Settings ===
# The domain your app is hosted on (e.g. share.example.com)
SITE_DOMAIN=localhost

# Custom branding name
SITE_NAME=P2P File Share

# Admin email for Let's Encrypt SSL/TLS certificates registration
ADMIN_EMAIL=admin@localhost

# === Autogenerated Secrets (Setup script generates these) ===
ADMIN_JWT_SECRET=your-32plus-chars-jwt-secret-key-goes-here-and-is-required
TURN_SECRET=your-secure-turn-rest-api-secret-key
POSTGRES_PASSWORD=your-secure-postgres-password-here

# === Optional Customizations ===
# Admin cookie scope (defaults to SITE_DOMAIN if not set)
# ADMIN_COOKIE_DOMAIN=share.example.com
# Telemetry (disabled by default for self-hosters)
# VITE_TELEMETRY_ENABLED=false
# VITE_API_URL=https://share.example.com
# VITE_PEERJS_HOST=share.example.com
# VITE_PEERJS_PORT=443
# VITE_PEERJS_PATH=/peerjs
# VITE_PEERJS_SECURE=true
# VITE_GITHUB_URL=https://github.com/your-username/repo-name
# VITE_SUPPORT_URL=https://buymeacoffee.com/your-page
# VITE_COPYRIGHT_HOLDER=Your Name
