# Metadata API Configuration - Production VPS

# Server
NODE_ENV=production
PORT=3001

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=p2p_metadata
POSTGRES_USER=p2p_api_user
POSTGRES_PASSWORD=P2P_Secure_Pass_2024!
POSTGRES_MAX_CONNECTIONS=20

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Link Configuration
LINK_EXPIRY_HOURS=24
CLEANUP_INTERVAL_MINUTES=60

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=https://p2p.red
