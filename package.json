{
  "name": "p2p-file-share",
  "version": "1.0.0",
  "description": "Privacy-first P2P file sharing using WebRTC DataChannels",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "npx serve -s dist -l 3000",
